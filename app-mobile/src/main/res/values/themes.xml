<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Text.BottomNav" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">10sp</item>
    </style>

    <style name="Theme.LomenMobile" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="colorPrimary">@color/primary_yellow</item>
        <item name="colorOnPrimary">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorControlHighlight">@color/ripple_highlight</item>
        <item name="android:colorControlHighlight">@color/ripple_highlight</item>
        <item name="actionBarSize">@dimen/toolbar_height</item>
        <item name="toolbarStyle">@style/Widget.Lomen.Toolbar</item>
    </style>

    <style name="Theme.LomenMobile.Splash" parent="Theme.LomenMobile">
        <item name="android:windowBackground">@drawable/ic_splash</item>
    </style>

    <style name="Text.Lomen.ToolbarTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/toolbar_title_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.Lomen.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:minHeight">@dimen/toolbar_height</item>
        <item name="titleTextAppearance">@style/Text.Lomen.ToolbarTitle</item>
        <item name="android:paddingLeft">4dp</item>
        <item name="android:paddingRight">4dp</item>
        <item name="contentInsetStartWithNavigation">0dp</item>
    </style>

    <style name="Theme.LomenMobile.Player" parent="Theme.LomenMobile">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.LomenMobile.DownloadProgress" parent="Theme.LomenMobile">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>

    <style name="Text.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.MoreLink" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/primary_yellow</item>
    </style>

    <style name="Widget.LomenTextLink" parent="">
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:textColor">@color/primary_yellow</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingVertical">4dp</item>
    </style>

    <style name="Widget.Lomen.PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary_yellow</item>
        <item name="android:textColor">@color/background_dark</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <style name="Widget.Lomen.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/bottom_nav_indicator</item>
    </style>
</resources>
