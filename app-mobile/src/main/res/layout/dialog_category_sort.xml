<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    android:layout_width="match_parent"

    android:layout_height="wrap_content"

    android:background="@drawable/bg_settings_dialog_panel"

    android:orientation="vertical"

    android:paddingHorizontal="14dp"

    android:paddingTop="12dp"

    android:paddingBottom="12dp">



    <TextView

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:text="@string/settings_home_sort"

        android:textColor="@color/text_primary"

        android:textSize="15sp"

        android:textStyle="bold" />



    <ProgressBar

        android:id="@+id/loading_indicator"

        android:layout_width="24dp"

        android:layout_height="24dp"

        android:layout_gravity="center_horizontal"

        android:layout_marginTop="12dp"

        android:indeterminateTint="@color/primary_yellow"

        android:visibility="gone" />



    <TextView

        android:id="@+id/error_text"

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:layout_marginTop="8dp"

        android:textColor="@color/error_red"

        android:textSize="12sp"

        android:visibility="gone" />



    <FrameLayout

        android:id="@+id/sort_list_container"

        android:layout_width="match_parent"

        android:layout_height="180dp"

        android:layout_marginTop="8dp">



        <androidx.recyclerview.widget.RecyclerView

            android:id="@+id/sort_recycler"

            android:layout_width="match_parent"

            android:layout_height="match_parent"

            android:clipToPadding="false"

            android:nestedScrollingEnabled="true"

            android:overScrollMode="never"

            android:scrollbars="vertical" />

    </FrameLayout>



    <LinearLayout

        android:id="@+id/button_row"

        android:layout_width="match_parent"

        android:layout_height="wrap_content"

        android:layout_marginTop="12dp"

        android:orientation="horizontal">



        <TextView

            android:id="@+id/cancel_button"

            android:layout_width="0dp"

            android:layout_height="36dp"

            android:layout_marginEnd="8dp"

            android:layout_weight="1"

            android:background="@drawable/ripple_settings_dialog_btn_close"

            android:clickable="true"

            android:focusable="true"

            android:gravity="center"

            android:text="@string/player_close"

            android:textColor="@color/text_primary"

            android:textSize="13sp" />



        <TextView

            android:id="@+id/save_button"

            android:layout_width="0dp"

            android:layout_height="36dp"

            android:layout_weight="1"

            android:background="@drawable/ripple_settings_dialog_btn_save"

            android:clickable="true"

            android:focusable="true"

            android:gravity="center"

            android:text="@string/settings_save"

            android:textColor="@color/background_dark"

            android:textSize="13sp"

            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>

