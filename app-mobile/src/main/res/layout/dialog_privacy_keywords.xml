<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_settings_dialog_panel"
    android:orientation="vertical"
    android:paddingHorizontal="14dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_privacy_keywords"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/settings_privacy_keywords_hint"
        android:textColor="@color/text_secondary"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/keywords_input"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_settings_input"
        android:hint="@string/settings_privacy_keywords_placeholder"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:paddingHorizontal="12dp"
        android:singleLine="true"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/cancel_button"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/ripple_settings_dialog_btn_close"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/player_close"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/save_button"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/ripple_settings_dialog_btn_save"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/settings_save"
            android:textColor="@color/background_dark"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
